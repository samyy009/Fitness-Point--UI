# Server
PORT=5000
NODE_ENV=development

# PostgreSQL Database
DATABASE_URL=postgresql://username:password@localhost:5432/fitness_point
# OR individual fields:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fitness_point
DB_USER=postgres
DB_PASSWORD=yourpassword

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Admin seed credentials
ADMIN_EMAIL=admin@fitnesspoint.com
ADMIN_PASSWORD=Admin@123
